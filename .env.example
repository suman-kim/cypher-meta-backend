# 서버
PORT=4000
CORS_ORIGIN=http://localhost:3000

# 로컬 Postgres (이미 설치된 인스턴스에 맞춰 값 수정)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=admin
DB_PASSWORD=admin
DB_NAME=cyphers
# 개발 중에는 true → 엔티티대로 테이블 자동 생성/동기화 (운영은 false + 마이그레이션)
DB_SYNC=true

# Neople 오픈API (백엔드에서 프록시/캐싱)
NEOPLE_API_KEY=여기에_발급받은_키를_입력하세요

# 메타 자동 수집 스케줄러 (부팅 후 최초 1회 + 주기 수집)
META_AUTO_COLLECT=true          # false 로 끄기
META_COLLECT_INTERVAL_HOURS=6   # 수집 주기(시간)
META_COLLECT_INITIAL_DELAY_SEC=30  # 부팅 후 최초 수집까지 지연(초)
META_COLLECT_RANKERS=20         # 수집할 상위 랭커 수
META_COLLECT_PER_PLAYER=10      # 플레이어당 매치 수
META_COLLECT_GAME_TYPE=rating   # rating(공식전) | normal(일반전)

# ===== 프로덕션 / Vercel 배포용 =====
# Neon 등 호스팅 DB 연결 문자열 (설정되면 위 DB_HOST/PORT/... 대신 이걸 사용).
# → Neon의 "Pooled connection"(호스트명에 -pooler 포함) 문자열을 추천.
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DB_SSL=true                     # 서버리스 Postgres는 SSL 필요 (DATABASE_URL 있으면 기본 true)
DB_POOL_MAX=5                   # 커넥션 풀 최대치 (서버리스면 작게)

# Vercel Cron 보안 — Vercel 프로젝트 환경변수에 동일값 설정 시,
# /api/meta/cron/collect 는 Authorization: Bearer <값> 이 있어야 실행됨.
CRON_SECRET=
